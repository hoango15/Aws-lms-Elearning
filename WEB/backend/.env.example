# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=online_learning_system

# JWT Authentication Config
JWT_SECRET=super_secret_jwt_key_change_me_in_production
